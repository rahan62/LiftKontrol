# -----------------------------------------------------------------------------
# Supabase (recommended for local dev: web + native use the same project)
# -----------------------------------------------------------------------------
# Direct Postgres (migrations: npm run db:migrate, seed, server-side pg when used).
# Replace YOUR_PASSWORD with your database password (Dashboard → Project Settings → Database).
# If the password contains @, #, /, etc., URL-encode it in this string.
#
# `npm run db:migrate` skips 20250325000000_local_postgres_prereq.sql on Supabase (that file is only for plain local Postgres).
#
# NOTE: db.<ref>.supabase.co is often IPv6-only. If you get ENOTFOUND or "getaddrinfo ENOTFOUND",
# switch DATABASE_URL to the Session pooler URI from the Dashboard (Connect → Session mode):
#   host: aws-0-<region>.pooler.supabase.com port 5432
#   user: postgres.exmcayqqwlaqqnardids  (not plain "postgres")
# Copy the full URI from Supabase and keep ?sslmode=require
#
# TLS: `src/lib/db/pool.ts` Supabase hostlarında (pooler/db) pg için `rejectUnauthorized: false` kullanır
# (`scripts/migrate.cjs` ile aynı; aksi halde SELF_SIGNED_CERT_IN_CHAIN sık görülür).
# Hâlâ aynı hata çıkarsa (kurumsal proxy hem Postgres hem HTTPS Auth’u kesiyorsa), yalnızca geliştirmede:
# NODE_TLS_REJECT_UNAUTHORIZED=0
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.exmcayqqwlaqqnardids.supabase.co:5432/postgres?sslmode=require
# After switching to the pooler, DATABASE_URL looks like (copy yours from the Dashboard; do not guess the region):
# DATABASE_URL=postgresql://postgres.exmcayqqwlaqqnardids:YOUR_PASSWORD@aws-0-....pooler.supabase.com:5432/postgres?sslmode=require

# API URL + anon key (Dashboard → Project Settings → API). Required for Supabase Auth in the browser and native apps.
NEXT_PUBLIC_SUPABASE_URL=https://exmcayqqwlaqqnardids.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Admin API — only for local scripts (npm run db:seed-supabase-admin). Never expose to the client or commit.
SUPABASE_SERVICE_ROLE_KEY=

# First admin on a new Supabase project (used by db:seed-supabase-admin only).
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Platform yönetim paneli (`admin/`, `npm run dev:admin`, varsayılan port 3001). Aynı Supabase Auth hesabına
# `platform_operators` kaydı ekler. Önce seed-supabase-admin; sonra: `npm run db:seed-platform-operator`
# Admin uygulamasında yeni kullanıcı oluşturmak için SUPABASE_SERVICE_ROLE_KEY sunucuda gerekir (asla client’a vermeyin).
SEED_PLATFORM_ADMIN_EMAIL=
# SEED_PLATFORM_ADMIN_ROLE=owner

# Ek kullanıcı (ör. teknisyen): `npm run db:seed-user` — ortamda SEED_USER_EMAIL, SEED_USER_PASSWORD, SEED_USER_ROLE=technician
# İsteğe bağlı SEED_TARGET_TENANT_ID; yoksa ilk tenant_members satırının kiracısı kullanılır.

# Site URL for auth redirects / links (use LAN IP if you test from a phone on Wi‑Fi).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# QR ve native API çağrıları için web kökü (iOS `PUBLIC_APP_URL` ile aynı). Öntanımlı: localhost.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Günlük sevk (saha ekipleri, en fazla 10 durak): `GET /api/cron/daily-dispatch?secret=...&force=1`
# force=1 saat kontrolünü atlar (test). Üretimde Vercel Cron + İstanbul 06:00. Doğrudan PG (DATABASE_URL) gerekir.
# CRON_SECRET=

# JWT signing when you still use local auth endpoints alongside Supabase (optional in dev).
# Use at least 32 random characters if set.
LOCAL_AUTH_SECRET=

# -----------------------------------------------------------------------------
# Optional: purely local Postgres (no Supabase) — uncomment and comment DATABASE_URL above instead.
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/ElevatorMaintenance

# LAN hostname(s) for Next dev HMR when you open the app by IP (Expo Go / phone). Comma-separated, no scheme.
# Example: ipconfig getifaddr en0 → put that value here.
# NEXT_ALLOWED_DEV_ORIGINS=192.168.68.101

# -----------------------------------------------------------------------------
# Object storage (AWS S3, Supabase Storage S3 API, veya diğer S3 uyumlu servisler)
# -----------------------------------------------------------------------------
# Tanımlıysa yeni yüklemeler bucket’a gider; veritabanında yol `s3:kiracı/kategori/dosya` olarak saklanır.
# Tanımsızsa davranış eskisi gibi yerel `uploads/` klasörüdür (Vercel’de kalıcı değildir).
#
# --- Supabase Storage (S3 protocol) ---
# Dashboard → Project Settings → Storage → enable S3 connection → create access key.
# Bucket = Storage’da oluşturduğunuz bucket adı (ör. field-uploads). Region = proje bölgeniz (ör. eu-central-1).
# S3_ENDPOINT otomatik türetilir: NEXT_PUBLIC_SUPABASE_URL=https://REF.supabase.co ise
#   https://REF.storage.supabase.co/storage/v1/s3 kullanılır (forcePathStyle açık).
# İsterseniz elle:
# SUPABASE_STORAGE_S3_ENDPOINT=https://YOUR_REF.storage.supabase.co/storage/v1/s3
#
# S3_BUCKET=field-uploads
# AWS_REGION=eu-central-1
# Gerçek anahtarları tırnak/<> olmadan yapıştırın; `<...>` veya REPLACE_ME gibi değerler yok sayılır (yerel uploads/).
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
#
# --- Saf AWS S3 ---
# AWS_S3_BUCKET=my-company-docs
# AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# (S3_ENDPOINT yok — AWS SDK varsayılan uç noktayı kullanır)
#
# Alternatif bucket adı:
# S3_BUCKET=my-company-docs
#
# MinIO / DigitalOcean Spaces:
# S3_ENDPOINT=https://minio.example.com
# S3_FORCE_PATH_STYLE=1

# -----------------------------------------------------------------------------
# iyzico (tek ürün / Checkout Form — /odeme, callback: /api/iyzico/callback)
# -----------------------------------------------------------------------------
# Sandbox: https://sandbox-api.iyzipay.com — Production: https://api.iyzipay.com
# IYZIPAY_URI=https://sandbox-api.iyzipay.com
# IYZIPAY_API_KEY=
# IYZIPAY_SECRET_KEY=
# Panelde callback URL: {NEXT_PUBLIC_APP_URL veya NEXT_PUBLIC_SITE_URL}/api/iyzico/callback (HTTPS üretimde zorunlu).
#
# Fiyat: platform_settings’ten gelen ana fiyat (marketing). KDV:
# IYZICO_PRICE_INCLUDES_VAT=0 → fiyata KDV eklenir (IYZICO_VAT_RATE, öntanımlı 0.2)
# IYZICO_PRICE_INCLUDES_VAT=1 → gösterilen fiyat KDV dahil kabul edilir
# IYZICO_VAT_RATE=0.2
# Sandbox’ta gerçek olmayan TCKN ile test: IYZICO_ALLOW_SANDBOX_TC=1 (yalnızca sandbox)
