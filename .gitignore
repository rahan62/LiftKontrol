# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
# Root uses npm (package-lock.json). Avoid committing a stale pnpm lock; Vercel otherwise picks pnpm and can fail CI.
/pnpm-lock.yaml
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
admin/.next/
/out/

# production
/build

# Expo
.expo/

# misc
.DS_Store
# Large local standard PDFs (use OCR + import script instead of committing)
scripts/*.pdf
*.pem
*.p8
AuthKey_*.p8

# Local uploads (contracts, etc.); production will use object storage
/uploads

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Native — local secrets (same idea as .env.local)
native/ios/**/Config/Local.xcconfig
native/android/local.properties

# Xcode / Android build artifacts
native/ios/**/*.xcworkspace/xcuserdata
native/ios/**/*.xcodeproj/xcuserdata
native/ios/**/DerivedData
native/android/.gradle
native/android/**/build
native/android/**/.idea
native/android/**/*.iml
native/android/captures
